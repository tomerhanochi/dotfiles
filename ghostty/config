# --- Shell & Startup ---
# Launches zsh and automatically attaches to Zellij
command = /bin/zsh -c "exec zellij attach terminal"

# --- Window Appearance ---
# Removes all decorations (Title bars, buttons, etc.)
maximize = true
macos-titlebar-style = hidden
window-decoration = false

# --- Font Settings ---
font-family = Intel One Mono
font-size = 16
font-style = Medium

# --- Input & Keyboard ---
macos-option-as-alt = true

# --- Theme ---
theme = Tomorrow Night

# --- Behaviour ---
confirm-close-surface = false

# --- Shell Integration ---
shell-integration = zsh
shell-integration-features = ssh-env,sudo
